# Create .env.example template (safe to commit)
cat > .env.example << 'EOF'
# OpenWeatherMap API Configuration
# Get your free API key: https://home.openweathermap.org/users/sign_up

OPENWEATHER_API_KEY=your_api_key_here

# Optional: Add other API keys if needed in the future
# GOOGLE_MAPS_API_KEY=your_google_maps_key
# WEATHERBIT_API_KEY=your_weatherbit_key

# App Configuration (optional)
# DEBUG=False
# LOG_LEVEL=INFO
EOF